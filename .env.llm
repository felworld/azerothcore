# Session mode: LLM — playerbots on, agentic LLM bots on.
#
# Usage: docker-compose --env-file .env.llm up -d
#
# COMPOSE_PROFILES=llm starts the ac-vllm GPU container. First start downloads
# the model from Hugging Face (worldserver reaches it lazily, so it won't block
# the game server). Export HF_TOKEN (a read-scope token from
# https://huggingface.co/settings/tokens) before that first start to avoid
# anonymous rate limits — it's a secret, so it does not belong in this file.
# Model/parsers are swappable here (see docker-compose.yml for the defaults,
# which follow NVIDIA's DGX Spark agent-ready Qwen3.6 recipe):
#   VLLM_MODEL=nvidia/Qwen3.6-35B-A3B-NVFP4
#   VLLM_TOOL_PARSER=qwen3_xml
#   VLLM_REASONING_PARSER=qwen3
COMPOSE_PROFILES=llm
AC_AI_PLAYERBOT_ENABLED=1
AC_LLM_ENABLE=1

# Force off playerbots' own canned chatter — mod-llm provides the LLM
# equivalents, so leaving these on double-chatters. Only set here (in llm
# mode); solo/dumbbots leave them unset so the playerbots.conf values apply.
# (GuildFeedback is inert in this mod-playerbots build but kept for parity.)
AC_AI_PLAYERBOT_ENABLE_BROADCASTS=0
AC_AI_PLAYERBOT_RANDOM_BOT_TALK=0
AC_AI_PLAYERBOT_RANDOM_BOT_EMOTE=0
AC_AI_PLAYERBOT_RANDOM_BOT_SUGGEST_DUNGEONS=0
AC_AI_PLAYERBOT_ENABLE_GREET=0
AC_AI_PLAYERBOT_GUILD_FEEDBACK=0
AC_AI_PLAYERBOT_RANDOM_BOT_SAY_WITHOUT_MASTER=0
AC_AI_PLAYERBOT_WPVP_CALLOUTS=0
