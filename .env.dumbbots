# Session mode: DUMB BOTS — playerbots on, no LLM (rule-based bot AI only).
#
# Usage: docker-compose --env-file .env.dumbbots up -d
#
# COMPOSE_PROFILES is empty, so the ac-ollama container stays down; bots run on
# playerbots' built-in (non-LLM) AI.
COMPOSE_PROFILES=
AC_AI_PLAYERBOT_ENABLED=1
AC_OLLAMA_CHAT_ENABLE=0
