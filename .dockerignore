/cmake-build-debug/*
/build*/
/var/*
!/var/build/.gitkeep
!/var/ccache/.gitkeep
/env/dist/*
!/env/dist/.gitkeep
/env/user/*
/.env*
.idea
!.gitkeep

# Git history (~1GB) is not needed in the build context. The build no longer
# bind-mounts .git; the version string is stamped via -DWITHOUT_GIT in
# apps/docker/Dockerfile. Excludes the root repo and any submodule .git dirs.
.git
**/.git

# SQL source tree (~800MB) is no longer baked into the db-import image; it's
# bind-mounted at runtime instead (see ac-db-import in docker-compose.yml).
# Anchored to the repo root so module SQL (modules/*/data/sql) is unaffected.
/data

# do not ignore the ccache folder (used by the ci)
!/var/docker/ccache
