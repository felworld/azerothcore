# Session mode: SOLO — no playerbots, no LLM bots.
#
# Usage: docker-compose --env-file .env.solo up -d
#
# COMPOSE_PROFILES is empty, so the ac-vllm container is never started.
# Only ac-worldserver is recreated on a mode switch (its env changed); the
# database/authserver keep running untouched.
COMPOSE_PROFILES=
AC_AI_PLAYERBOT_ENABLED=0
AC_LLM_ENABLE=0
