# Session mode: OLLAMA — playerbots on, LLM chat on.
#
# Usage: docker-compose --env-file .env.ollama up -d
#
# COMPOSE_PROFILES=ollama starts the ac-ollama GPU container. First start pulls
# the model (worldserver reaches it lazily, so it won't block the game server).
COMPOSE_PROFILES=ollama
AC_AI_PLAYERBOT_ENABLED=1
AC_OLLAMA_CHAT_ENABLE=1
