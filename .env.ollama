# Session mode: OLLAMA — playerbots on, LLM chat on.
#
# Usage: docker-compose --env-file .env.ollama up -d
#
# COMPOSE_PROFILES=ollama starts the ac-ollama GPU container. First start pulls
# the model (worldserver reaches it lazily, so it won't block the game server).
COMPOSE_PROFILES=ollama
AC_AI_PLAYERBOT_ENABLED=1
AC_OLLAMA_CHAT_ENABLE=1

# Force off playerbots' own canned chatter — mod-ollama-chat provides the LLM
# equivalents, so leaving these on double-chatters. This is the set its README
# recommends disabling. Only set here (in ollama mode); solo/dumbbots leave them
# unset so the playerbots.conf values apply. (GuildFeedback is inert in this
# mod-playerbots build but kept for parity.)
AC_AI_PLAYERBOT_ENABLE_BROADCASTS=0
AC_AI_PLAYERBOT_RANDOM_BOT_TALK=0
AC_AI_PLAYERBOT_RANDOM_BOT_EMOTE=0
AC_AI_PLAYERBOT_RANDOM_BOT_SUGGEST_DUNGEONS=0
AC_AI_PLAYERBOT_ENABLE_GREET=0
AC_AI_PLAYERBOT_GUILD_FEEDBACK=0
AC_AI_PLAYERBOT_RANDOM_BOT_SAY_WITHOUT_MASTER=0
